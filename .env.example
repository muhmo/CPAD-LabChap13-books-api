# .env.example (and copy to .env)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=books_api
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=3600
JWT_ISSUER=books-api

# Comma-separated; include your Vercel URL when deployed
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://cpad-lab-chap13.vercel.app

APP_DEBUG=true